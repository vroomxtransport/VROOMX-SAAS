# Supabase (Public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase (Secret - server only)
SUPABASE_SECRET_KEY=sb_secret_...

# Database (server only)
DATABASE_URL=postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres.ref:password@aws-0-region.supabase.com:5432/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Tier price IDs — create one price per tier in the Stripe dashboard
# and paste the IDs here. Plan keys match src/types/index.ts SubscriptionPlan.
STRIPE_OWNER_OPERATOR_PRICE_ID=price_...
STRIPE_STARTER_X_PRICE_ID=price_...
STRIPE_PRO_X_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_...

# Upstash Redis (rate limiting — REQUIRED in production, falls back to in-memory in dev)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# Cron secret (REQUIRED — bearer token for /api/cron/* endpoints, set the same value in your cron service)
CRON_SECRET=generate-a-long-random-string

# EIA API key for fuel pricing endpoint (REQUIRED — get one at https://www.eia.gov/opendata/register.php)
EIA_API_KEY=your_eia_api_key

# Chrome extension allowlist (REQUIRED in production — comma-separated full origins)
# Format: chrome-extension://<extension-id>,chrome-extension://<other-id>
EXTENSION_ALLOWED_IDS=chrome-extension://your_prod_extension_id_here

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Platform Admin (comma-separated emails for admin panel access)
PLATFORM_ADMIN_EMAILS=admin@yourcompany.com

# Samsara OAuth (for multi-tenant ELD/telematics integration)
SAMSARA_CLIENT_ID=your_client_id
SAMSARA_CLIENT_SECRET=your_client_secret
SAMSARA_REDIRECT_URI=https://your-app.com/api/samsara/callback

# QuickBooks Online OAuth (for accounting integration)
QUICKBOOKS_CLIENT_ID=your_client_id
QUICKBOOKS_CLIENT_SECRET=your_client_secret
QUICKBOOKS_REDIRECT_URI=https://your-app.com/api/quickbooks/callback
QUICKBOOKS_WEBHOOK_VERIFIER=your_verifier_token

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@vroomx.app
