{
  "manifest_version": 3,
  "name": "VroomX TMS - PDF Import",
  "version": "1.0.0",
  "description": "Import dispatch sheet PDFs into VroomX TMS with one click",
  "permissions": ["activeTab", "storage", "cookies", "tabs", "contextMenus", "scripting"],
  "host_permissions": [
    "https://*.vroomx.com/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "*://*.centraldispatch.com/*",
    "*://centraldispatch.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://app.centraldispatch.com/*",
        "*://www.centraldispatch.com/*",
        "*://site.centraldispatch.com/*",
        "*://centraldispatch.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
